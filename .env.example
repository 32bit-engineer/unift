# ============================================================
#  UniFT — Environment Variables
#  Copy this file to .env and fill in every required value.
#  NEVER commit .env to version control.
# ============================================================

# ── Database (required)
# Full JDBC URL for PostgreSQL, e.g.:
#   Local:  jdbc:postgresql://localhost:5432/unift_db
#   Docker: jdbc:postgresql://host.docker.internal:5432/unift_db
#   Cloud:  jdbc:postgresql://<host>:<port>/<db>?sslmode=require
DB_URL=jdbc:postgresql://localhost:5432/unift_db
DB_USERNAME=postgres
DB_PASSWORD=

# ── JWT (required)
# Generate with: openssl rand -base64 64
JWT_SECRET=
JWT_ACCESS_TOKEN_EXPIRATION_MS=900000
JWT_REFRESH_TOKEN_EXPIRATION_MS=604800000

# ── SSH credential encryption (required)
# AES-256-GCM key -- generate with: openssl rand -base64 32
UNIFT_ENCRYPTION_KEY=

# ── Kafka (optional)
# Kafka is wired but not actively consumed in v1.1.0.
# Leave as localhost:9092 if you have no broker; startup warnings are expected.
KAFKA_BOOTSTRAP_SERVERS=localhost:9092
KAFKA_CONSUMER_GROUP_ID=unift-group

# ── Ports
API_PORT=8080
APP_PORT=80

# ── Frontend build args (baked in at image build time)
# Leave VITE_API_BASE_URL blank to use the nginx proxy for /api/* (recommended for docker-compose).
# Set to http://localhost:8080/api only when running the Vite dev server directly.
VITE_API_BASE_URL=
VITE_APP_NAME=UniFT
VITE_APP_VERSION=1.1.0
VITE_ENABLE_DARK_MODE=true

# ── WebSocket CORS origins (comma-separated browser origins)
UNIFT_TERMINAL_ALLOWED_ORIGINS=http://localhost,http://localhost:80,http://localhost:3000,http://localhost:5173,http://localhost:8080,http://127.0.0.1:3000,http://127.0.0.1:5173

# ── Remote session settings (optional -- built-in defaults shown)
UNIFT_SESSION_TTL_MINUTES=30
UNIFT_MAX_SESSIONS_PER_USER=5
UNIFT_REAPER_INTERVAL_MS=60000
UNIFT_CONNECT_TIMEOUT_MS=15000
UNIFT_CHANNEL_TIMEOUT_MS=10000
UNIFT_SLIDING_TTL=true

# ── Logging (optional)
LOG_LEVEL_ROOT=INFO
LOG_LEVEL_APP=INFO
LOG_LEVEL_EXCEPTION=INFO

# ── Swagger try-it-out (set to false in production)
SWAGGER_TRY_IT_OUT=false


# ─────────────────────────────────────────────
# Swagger UI — set false in production
# ─────────────────────────────────────────────
SWAGGER_TRY_IT_OUT=false

# ─────────────────────────────────────────────
# Application ports
# APP_PORT  = browser-facing port (nginx / frontend)
# API_PORT  = backend port (exposed for direct access / debugging)
# ─────────────────────────────────────────────
APP_PORT=80
API_PORT=8080

# ─────────────────────────────────────────────
# Frontend build args (baked in at docker build time)
# ─────────────────────────────────────────────

VITE_API_BASE_URL=http://localhost:8080
VITE_APP_NAME=UniFT
VITE_APP_VERSION=0.0.1
VITE_ENABLE_DARK_MODE=true

# ─────────────────────────────────────────────
# Storage — host path mounted into the API container
# Change this to wherever your files live on the host
# ─────────────────────────────────────────────
STORAGE_PATH=/mnt/storage

