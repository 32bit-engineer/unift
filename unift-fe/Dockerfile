# ─────────────────────────────────────────────# Stage 1: Build the React/Vite app# ─────────────────────────────────────────────FROM node:22-alpine AS builderWORKDIR /appCOPY package*.json ./RUN npm ciCOPY . .# VITE_ vars are baked in at build time.# In Docker the nginx proxy makes everything same-origin,# so the API base URL is a relative path by default.ARG VITE_API_BASE_URL=/apiENV VITE_API_BASE_URL=$VITE_API_BASE_URLARG VITE_APP_NAME=UniFTENV VITE_APP_NAME=$VITE_APP_NAMEARG VITE_APP_VERSION=0.0.1ENV VITE_APP_VERSION=$VITE_APP_VERSIONARG VITE_ENABLE_DARK_MODE=trueENV VITE_ENABLE_DARK_MODE=$VITE_ENABLE_DARK_MODERUN npm run build# ─────────────────────────────────────────────# Stage 2: Serve with Nginx# ─────────────────────────────────────────────FROM nginx:1.27-alpine# Remove default nginx static contentRUN rm -rf /usr/share/nginx/html/*# Copy built assets from builder stageCOPY --from=builder /app/dist /usr/share/nginx/html# Copy custom nginx configCOPY nginx.conf /etc/nginx/conf.d/default.confEXPOSE 80CMD ["nginx", "-g", "daemon off;"]