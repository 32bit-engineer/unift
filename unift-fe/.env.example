# UniFT Frontend Environment Configuration
# Copy this file to .env.local and update with your actual values

# API Endpoints
VITE_API_BASE_URL=http://localhost:8080/api

# Authentication Endpoints
VITE_API_AUTH_LOGIN=http://localhost:8080/api/auth/login
VITE_API_AUTH_LOGOUT=http://localhost:8080/api/auth/logout

# File Management Endpoints
VITE_API_FILES_LIST=http://localhost:8080/api/files
VITE_API_FILES_UPLOAD=http://localhost:8080/api/files/upload
VITE_API_FILES_DELETE=http://localhost:8080/api/files
VITE_API_FILES_SEARCH=http://localhost:8080/api/files/search

# Transfer/History Endpoints
VITE_API_TRANSFERS_HISTORY=http://localhost:8080/api/transfers/history
VITE_API_TRANSFERS_STATS=http://localhost:8080/api/transfers/stats

# Admin Endpoints
VITE_API_ADMIN_PERMISSIONS=http://localhost:8080/api/admin/permissions
VITE_API_ADMIN_USERS=http://localhost:8080/api/admin/users

# Media/Playback Endpoints
VITE_API_MEDIA_STREAM=http://localhost:8080/api/media/stream

# Application Configuration
VITE_APP_NAME=UniFT
VITE_APP_VERSION=1.0.0

# Feature Flags
VITE_ENABLE_DARK_MODE=true
